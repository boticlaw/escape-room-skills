{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "prueba.schema.json",
  "title": "Escape Room Prueba Individual",
  "description": "Schema para prueba-*.json — definición detallada de una prueba individual",
  "type": "object",
  "required": [
    "id",
    "nombre",
    "descripcion",
    "dificultad",
    "duracion_estimada_minutos",
    "configuracion",
    "barrera_fisica",
    "hilo_conductor",
    "pistas",
    "solucion",
    "materiales",
    "documentos_in_game",
    "narrativa"
  ],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+_[0-9]+_[a-z0-9_-]+$",
      "description": "ID único de la prueba (ej: touring_001_real_o_falso)"
    },
    "nombre": {
      "type": "string"
    },
    "descripcion": {
      "type": "string"
    },
    "juego": {
      "type": "string"
    },
    "version": {
      "type": "integer"
    },
    "espacio": {
      "type": "integer",
      "minimum": 1
    },
    "sala": {
      "type": "string"
    },
    "tema_educativo": {
      "type": "string"
    },
    "skill_primario": {
      "type": "string"
    },
    "skills_secundarios": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dificultad": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "duracion_estimada_minutos": {
      "type": "integer",
      "minimum": 1
    },
    "jugadores_min": {
      "type": "integer"
    },
    "jugadores_max": {
      "type": "integer"
    },
    "edad_minima": {
      "type": "integer"
    },
    "cooperacion_obligatoria": {
      "type": "boolean"
    },
    "formato": {
      "type": "string",
      "enum": [
        "secuencial",
        "paralelo",
        "libre"
      ]
    },
    "configuracion": {
      "type": "object",
      "required": [
        "mecanica_principal",
        "mecanismo_barrera",
        "elementos_necesarios",
        "distribucion_roles"
      ],
      "additionalProperties": true,
      "properties": {
        "mecanica_principal": {
          "type": "string"
        },
        "elementos_necesarios": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "operador": {
          "type": "string"
        },
        "distribucion_roles": {
          "type": "object"
        },
        "mecanismo_barrera": {
          "type": "string"
        }
      }
    },
    "barrera_fisica": {
      "type": "object",
      "required": [
        "tipo"
      ],
      "additionalProperties": true,
      "properties": {
        "tipo": {
          "type": "string",
          "description": "Ej: Cryptex de 6 letras, Candado numérico de 4 dígitos, Llave física"
        },
        "codigo": {
          "type": "string"
        },
        "codigo_candado": {
          "type": "string"
        },
        "ubicacion": {
          "type": "string"
        },
        "origen_codigo": {
          "type": "string"
        },
        "montaje_minutos": {
          "type": "integer"
        }
      }
    },
    "hilo_conductor": {
      "type": "object",
      "required": [
        "letra",
        "significado"
      ],
      "additionalProperties": true,
      "properties": {
        "letra": {
          "type": "string",
          "maxLength": 2
        },
        "significado": {
          "type": "string"
        },
        "posicion": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "pistas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "nivel",
          "texto"
        ],
        "additionalProperties": true,
        "properties": {
          "nivel": {
            "type": "integer",
            "minimum": 1
          },
          "tipo": {
            "type": "string",
            "enum": [
              "sutil",
              "directa",
              "casi_solucion"
            ]
          },
          "timing": {
            "type": "string"
          },
          "texto": {
            "type": "string"
          }
        }
      }
    },
    "solucion": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "descripcion": {
          "type": "string"
        },
        "verificacion": {
          "type": "string"
        },
        "pasos_detallados": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recompensa": {
          "type": "object"
        }
      }
    },
    "materiales": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "impresion": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mobiliario": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "extras": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "documentos_in_game": {
      "type": "array",
      "description": "Alias para ingame_docs (compatibilidad)",
      "items": {
        "type": "object",
        "required": [
          "titulo",
          "texto"
        ],
        "additionalProperties": true,
        "properties": {
          "titulo": {
            "type": "string"
          },
          "texto": {
            "type": "string"
          },
          "cantidad": {
            "type": "integer"
          },
          "gm_notas": {
            "type": "string"
          }
        }
      }
    },
    "materiales_html": {
      "type": "string"
    },
    "narrativa": {
      "type": "string"
    },
    "objetivos": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "control_movimiento": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "problema_potencial": {
          "type": "string"
        },
        "solucion_implementada": {
          "type": "string"
        },
        "tipo_solucion": {
          "type": "string"
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "autor": {
          "type": "string"
        },
        "fecha_creacion": {
          "type": "string",
          "format": "date"
        },
        "fecha_actualizacion": {
          "type": "string",
          "format": "date"
        },
        "version": {
          "type": "integer"
        },
        "testado": {
          "type": "boolean"
        },
        "notas": {
          "type": "string"
        }
      }
    }
  }
}