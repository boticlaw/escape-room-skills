{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "game.schema.json",
  "title": "Escape Room Game Definition",
  "description": "Schema para game.json — metadata global del juego + referencias a pruebas. Los JSONs de prueba son la fuente de verdad detallada.",
  "type": "object",
  "required": ["nombre", "pruebas"],
  "additionalProperties": false,
  "properties": {
    "nombre": {
      "type": "string",
      "minLength": 1,
      "description": "Nombre del escape room"
    },
    "subtitulo": {
      "type": "string",
      "description": "Subtítulo descriptivo"
    },
    "tipo": {
      "type": "string",
      "enum": ["verde", "rojo", "azul", "violeta", "naranja", "oscuro"],
      "default": "verde",
      "description": "Paleta de colores del PDF"
    },
    "version": {
      "type": "string",
      "description": "Versión del diseño (ej: '2.2')"
    },
    "fecha": {
      "type": "string",
      "description": "Fecha del diseño (ej: 'Abril 2026')"
    },
    "meta": {
      "type": "array",
      "description": "Metadatos del juego mostrados en portada (formato label/value)",
      "items": {
        "type": "object",
        "required": ["label", "value"],
        "additionalProperties": false,
        "properties": {
          "label": { "type": "string" },
          "value": { "type": "string" }
        }
      }
    },
    "secciones": {
      "type": "array",
      "description": "Secciones de contenido global (sinopsis, personajes, flujo, etc.)",
      "items": {
        "type": "object",
        "required": ["titulo", "contenido_html"],
        "additionalProperties": false,
        "properties": {
          "titulo": { "type": "string" },
          "contenido_html": { "type": "string" }
        }
      }
    },
    "pruebas": {
      "type": "array",
      "description": "Lista de referencias a pruebas individuales (fuente de verdad: JSONs en juego/pruebas/)",
      "items": {
        "type": "object",
        "required": ["id", "archivo"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^prueba-[0-9]{3}$",
            "description": "ID de referencia (ej: prueba-001)"
          },
          "archivo": {
            "type": "string",
            "pattern": "^prueba-[0-9]{3}-.+\\.json$",
            "description": "Nombre del archivo JSON en juego/pruebas/"
          }
        }
      }
    },
    "historial_versiones": {
      "type": "array",
      "description": "Historial de versiones del diseño",
      "items": {
        "type": "object",
        "required": ["version", "fecha", "tipo", "descripcion"],
        "additionalProperties": false,
        "properties": {
          "version": { "type": "string" },
          "fecha": { "type": "string" },
          "tipo": { "type": "string", "enum": ["patch", "minor"] },
          "descripcion": { "type": "string" }
        }
      }
    },
    "checklist_html": {
      "type": "string",
      "description": "HTML de la tabla de checklist de materiales del GM"
    },
    "secciones_final": {
      "type": "array",
      "description": "Secciones del final del documento",
      "items": {
        "type": "object",
        "required": ["titulo", "contenido_html"],
        "additionalProperties": false,
        "properties": {
          "titulo": { "type": "string" },
          "contenido_html": { "type": "string" }
        }
      }
    }
  }
}
