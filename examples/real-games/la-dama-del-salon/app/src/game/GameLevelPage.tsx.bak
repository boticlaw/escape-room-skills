import React, { useEffect, useState } from 'react';
import { useParams, useNavigate } from 'react-router-dom';
import { useAuth } from 'wasp/client/auth';
import { getUserGameProgress, updateGameProgress } from 'wasp/client/operations';
import LevelGuard from './components/LevelGuard';
import VideoModal from './components/VideoModal';
import GeoLocationChecker, { GeoCoordinates } from './components/GeoLocationChecker';

// Interfaz para el tipo de nivel
interface LevelData {
  title: string;
  description: string;
  imageUrl: string;
  hint: string;
  solution: string;
  diaryContent?: string;
  location?: GeoCoordinates; // Coordenadas de geolocalización
}

// Ejemplo de datos de niveles (en una aplicación real, probablemente los obtendrías de una API o base de datos)
const LEVELS_DATA: Record<string, LevelData> = {
  "1": {
    title: "El diario de Clara Vela",
    description: "15 de abril de 1897",
    imageUrl: "/level1.jpg",
    hint: "Busca referencias a un lugar en Palencia donde había música. Fíjate en lo que está destacado.",
    solution: "templete",
    diaryContent: `Hoy, como cada amanecer, he huido de mi propia casa antes de que alcancen a susurrar en los salones: quieren casarme con don Manuel de la Riva, un joven de la burguesía palentina cuya fortuna opaca cualquier atisbo de deseo propio. Al cerrar tras de mí el pesado portón de roble, siento un extraño alivio en el aire frío de la mañana; el crujir de las hojas secas bajo mis pasos me recuerda que todavía existe un lugar donde mi voz y mis sueños pueden flotar sin cadenas.
    Me he dirigido al claro junto al lugar que es un círculo de arte al aire libre, donde el viento lleva ritmos al atardecer, donde la bruma matinal envuelve las columnas de mármol y el canto distante de los pájaros se mezcla con el murmullo de mis pensamientos. Allí, acomodada sobre la piedra lisa que rodea el pilar sur, despliego mis cuadernos y abro con devoción el volumen de historia que me acompaña cada día. Hace ya varios meses, en una de mis lecturas casuales, encontré un pergamino firmado por el propio Ponce de León: relataba sus pesquisas sobre la legendaria Fuente de la Eterna Juventud. Me deleité con cada palabra, y desde entonces guardo aquel documento oculto entre las páginas de mi libro favorito.
    Hoy he retomado la lectura de aquel antiguo manuscrito junto al este lugar donde cada trazo de tinta me recuerda que la curiosidad es mi aliada más fiel; me impulsa a buscar respuestas más allá de las murallas familiares. Entre sus líneas, Ponce de León describe un manantial oculto "donde el agua susurra a las raíces de los sauces", y aunque dudo que tal prodigio exista en realidad, sus palabras me llenan de un fervor que ninguna boda convenida logrará distraer.
    Al cerrar mi diario y alzar la vista hacia la enigmática fuente de inspiración, sus columnas guardan ecos de trompetas y timbales, y en su techo habita el canto de bandurrias y pipas. Aqui el público se abisma en notas, y el silencio se viste de pentagramas.
    Percibo el eco de mi propia voz. Aquí, rodeada de columnas claveadas y bajo el dosel del temprano sol, hallo la fuerza para escribir mis secretos y perfilar, con trazos indelebles, mi propia historia. Mañana, volveré de nuevo, porque solo fuera de aquellos muros familiares mi espíritu encuentra la paz necesaria para soñar.
    `,
    location: {
      latitude: 42.0153, // Coordenadas de ejemplo para el Templete del Salón (reemplazar con las coordenadas reales)
      longitude: -4.5405,
      name: "Templete del Salón"
    }
  },
  "2": {
    title: "El reloj del tiempo",
    description: "Localiza el reloj antiguo y anota la hora exacta que marca. Esa hora tiene un significado especial.",
    imageUrl: "/level2.jpg",
    hint: "El reloj se encuentra en la fachada de un edificio histórico cerca de la catedral.",
    solution: "12:25",
    location: {
      latitude: 42.0109274, // Ejemplo (reemplazar con coordenadas reales)
      longitude: -4.5341823,
      name: "Reloj de la Catedral"
    }
  },
  "3": {
    title: "El mensaje cifrado",
    description: "Descifra el mensaje oculto utilizando la clave que encontrarás en la estatua del parque.",
    imageUrl: "/level3.jpg",
    hint: "La estatua tiene una inscripción en la base. Lee las primeras letras de cada línea.",
    solution: "BIBLIOTECA",
    location: {
      latitude: 42.0097619, // Ejemplo (reemplazar con coordenadas reales)
      longitude: -4.5210123,
      name: "Estatua del parque"
    }
  },
  // Agregar más niveles según sea necesario
};

// Función para resaltar palabras clave en el texto del diario y dar mejor formato
const highlightKeywords = (text: string, startIndex: number, endIndex: number) => {
  // Palabras a resaltar
  const keywords = [
    "templete", "columnas", "trompetas", "timbales", 
    "bandurrias", "música", "notas", "pentagramas",
    "círculo de arte al aire libre", "fuente de inspiración"
  ];
  
  // Dividir el texto en párrafos
  const paragraphs = text.split("\n\n");
  
  return paragraphs.slice(startIndex, endIndex).map((paragraph, index) => {
    // Resaltar palabras clave
    let highlightedParagraph = paragraph;
    keywords.forEach(keyword => {
      const regex = new RegExp(`\\b${keyword}\\b`, 'gi');
      highlightedParagraph = highlightedParagraph.replace(
        regex, 
        `<span class="text-amber-800 font-bold">$&</span>`
      );
    });
    
    return (
      <p 
        key={index} 
        className="mb-6 indent-6 leading-relaxed" 
        dangerouslySetInnerHTML={{ __html: highlightedParagraph }}
      />
    );
  });
};

const GameLevelPage = () => {
  const { levelId } = useParams<{ levelId: string }>();
  const { data: user } = useAuth();
  const navigate = useNavigate();
  const [answer, setAnswer] = useState("");
  const [showHint, setShowHint] = useState(false);
  const [message, setMessage] = useState({ text: "", type: "" });
  const [gameProgress, setGameProgress] = useState<any>(null);
  const [isLoading, setIsLoading] = useState(true);
  const [isVideoModalOpen, setIsVideoModalOpen] = useState(false);
  const [locationError, setLocationError] = useState<string | null>(null);

  // Nivel actual como número
  const currentLevel = parseInt(levelId || "1");
  const level = LEVELS_DATA[currentLevel.toString() as keyof typeof LEVELS_DATA];

  // Mostrar automáticamente el video cuando el nivel es 1
  useEffect(() => {
    if (currentLevel === 1) {
      setIsVideoModalOpen(true);
    }
  }, [currentLevel]);

  useEffect(() => {
    const fetchGameProgress = async () => {
      if (!user) return;

      try {
        const progress = await getUserGameProgress();
        setGameProgress(progress);
      } catch (error) {
        console.error('Error al obtener el progreso del juego:', error);
      } finally {
        setIsLoading(false);
      }
    };

    fetchGameProgress();
  }, [user, levelId]);

  // Función para manejar cuando el usuario ha llegado a la ubicación correcta
  const handleLocationReached = async () => {
    setMessage({ text: "¡Has llegado al lugar correcto!", type: "success" });

    try {
      // Actualizar el progreso del usuario
      await updateGameProgress({ 
        currentLevel: currentLevel + 1, 
        levelCompleted: true 
      });

      // Después de 2 segundos, redirigir al siguiente nivel
      setTimeout(() => {
        navigate(`/game/level/${currentLevel + 1}`);
      }, 2000);
    } catch (error) {
      console.error('Error al actualizar el progreso:', error);
      setMessage({ text: "Error al guardar el progreso", type: "error" });
    }
  };

  // Función para manejar errores de geolocalización
  const handleLocationError = (error: string) => {
    setLocationError(error);
    setMessage({ text: error, type: "error" });
  };

  const handleSubmitAnswer = async (e: React.FormEvent) => {
    e.preventDefault();

    if (!level) {
      setMessage({ text: "Nivel no encontrado", type: "error" });
      return;
    }

    if (answer.trim().toLowerCase() === level.solution.toLowerCase()) {
      setMessage({ text: "¡Respuesta correcta!", type: "success" });

      try {
        // Actualizar el progreso del usuario
        await updateGameProgress({ 
          currentLevel: currentLevel + 1, 
          levelCompleted: true 
        });

        // Después de 2 segundos, redirigir al siguiente nivel
        setTimeout(() => {
          navigate(`/game/level/${currentLevel + 1}`);
        }, 2000);
      } catch (error) {
        console.error('Error al actualizar el progreso:', error);
        setMessage({ text: "Error al guardar el progreso", type: "error" });
      }
    } else {
      setMessage({ text: "Respuesta incorrecta. Inténtalo de nuevo.", type: "error" });
      
      // Registrar el intento fallido
      try {
        await updateGameProgress({ wrongAttempts: 1 });
      } catch (error) {
        console.error('Error al registrar el intento fallido:', error);
      }
    }
  };

  const handleShowHint = async () => {
    setShowHint(true);
    
    // Registrar el uso de pista
    try {
      await updateGameProgress({ hintsUsed: 1 });
    } catch (error) {
      console.error('Error al registrar el uso de pista:', error);
    }
  };

  if (isLoading) {
    return (
      <div className="flex items-center justify-center h-screen">
        <div className="animate-spin rounded-full h-12 w-12 border-t-2 border-b-2 border-yellow-500"></div>
        <p className="ml-3">Cargando...</p>
      </div>
    );
  }

  if (!level) {
    return (
      <div className="min-h-screen flex items-center justify-center">
        <div className="text-center">
          <h1 className="text-3xl font-bold text-red-600">Nivel no encontrado</h1>
          <p className="mt-2">Lo sentimos, el nivel que buscas no existe.</p>
          <button
            onClick={() => navigate('/game')}
            className="mt-4 px-4 py-2 bg-yellow-600 text-white rounded-lg hover:bg-yellow-700"
          >
            Volver al inicio
          </button>
        </div>
      </div>
    );
  }

  // Renderizado especial para el nivel 1 (diario)
  if (currentLevel === 1) {
    // Obtener la fecha y el contenido del diario
    const diaryDate = level.diaryContent?.split('\n')[0] || '';
    const diaryText = level.diaryContent?.split('\n').slice(1).join('\n') || '';
    
    // Dividir y reorganizar los párrafos para mejorar legibilidad
    let paragraphs = diaryText.split('\n\n');
    
    // Asegurarse de que hay suficientes párrafos y que no son demasiado largos
    const reorganizedParagraphs: string[] = [];
    paragraphs.forEach(paragraph => {
      // Si un párrafo es muy largo (más de 300 caracteres), dividirlo
      if (paragraph.length > 300) {
        // Buscar un punto apropiado para dividir (cerca de la mitad)
        const sentences = paragraph.split('. ');
        let firstHalf = '';
        let secondHalf = '';
        
        if (sentences.length > 1) {
          const midpoint = Math.ceil(sentences.length / 2);
          firstHalf = sentences.slice(0, midpoint).join('. ') + '.';
          secondHalf = sentences.slice(midpoint).join('. ');
          
          reorganizedParagraphs.push(firstHalf);
          reorganizedParagraphs.push(secondHalf);
        } else {
          reorganizedParagraphs.push(paragraph);
        }
      } else {
        reorganizedParagraphs.push(paragraph);
      }
    });
    
    paragraphs = reorganizedParagraphs;
    
    // Configurar qué mostrar antes y después de la imagen
    const firstSectionEnd = 1; // Solo mostrar el primer párrafo antes de la imagen
    
    // Palabras a resaltar
    const keywords = [
      "templete", "columnas", "trompetas", "timbales", 
      "bandurrias", "música", "notas", "pentagramas",
      "círculo de arte al aire libre", "fuente de inspiración"
    ];

    // Función para resaltar keywords
    const highlightText = (text: string) => {
      let result = text;
      keywords.forEach((keyword: string) => {
        const regex = new RegExp(`\\b${keyword}\\b`, 'gi');
        result = result.replace(regex, `<span class="text-amber-800 font-bold">$&</span>`);
      });
      return result;
    };

    return (
      <LevelGuard>
        {/* Video Modal */}
        <VideoModal 
          isOpen={isVideoModalOpen} 
          onClose={() => setIsVideoModalOpen(false)}
          videoId="7XP7U0kIKVA"
        />
        
        <div className="min-h-screen bg-amber-50 py-12 px-4 sm:px-6 lg:px-8">
          <div className="max-w-3xl mx-auto">
            <div className="mb-6 flex justify-between items-center">
              <span className="inline-flex items-center px-3 py-1 bg-yellow-100 text-yellow-800 rounded-full text-sm font-medium">
                Nivel {currentLevel}
              </span>
            </div>
            
            <div className="bg-amber-100 border-amber-300 border shadow-lg rounded-lg overflow-hidden transform rotate-1 relative">
              {/* Esquinas de papel dobladas */}
              <div className="absolute top-0 right-0 w-0 h-0 border-0 border-t-[30px] border-r-[30px] border-amber-200 border-b-transparent border-l-transparent shadow-md"></div>
              <div className="absolute bottom-0 left-0 w-0 h-0 border-0 border-b-[30px] border-l-[30px] border-amber-200 border-t-transparent border-r-transparent shadow-md"></div>
              
              <div className="p-8 bg-gradient-to-r from-amber-50 to-amber-100 relative">
                {/* Adorno decorativo en la esquina superior izquierda - Pluma y compás */}
                <div className="absolute top-2 left-2 w-24 h-24 opacity-30">
                  <svg viewBox="0 0 100 100" className="w-full h-full text-amber-900">
                    <g transform="translate(5,5) scale(0.9)">
                      {/* Pluma estilizada */}
                      <path d="M20,80 C25,70 45,45 65,25 C70,20 80,15 85,10 C87,8 90,5 92,12 C93,16 90,20 88,22 C80,30 70,40 60,50 C50,60 40,70 30,80 C28,82 25,85 20,80 Z" fill="currentColor" opacity="0.7" />
                      <path d="M30,80 L20,80 C25,70 45,45 65,25 L75,25 C55,45 35,70 30,80 Z" fill="currentColor" opacity="0.3" />
                      {/* Compás estilizado */}
                      <circle cx="65" cy="40" r="18" stroke="currentColor" strokeWidth="2" fill="none" opacity="0.7" />
                      <path d="M65,22 L65,40 L78,40" stroke="currentColor" strokeWidth="2" fill="none" opacity="0.7" />
                      <circle cx="65" cy="40" r="2" fill="currentColor" opacity="0.7" />
                    </g>
                  </svg>
                </div>
                
                <div className="rotate-[-1deg]">
                  {/* TÍTULO PRINCIPAL DEL DIARIO */}
                  <h1 className="text-2xl font-bold text-amber-900 mb-6 font-serif text-center underline decoration-wavy decoration-amber-800 underline-offset-8">
                    {level.title}
                  </h1>
                  
                  {/* ESTRUCTURA COMPLETAMENTE NUEVA */}
                  <div className="font-serif text-amber-950">
                    {/* FECHA EN LA PARTE SUPERIOR - ESTILO SELLO VINTAGE */}
                    <div className="mb-10 flex justify-end">
                      <div className="relative">
                        {/* Círculo tipo sello */}
                        <div className="w-28 h-28 rounded-full border-2 border-amber-800 flex items-center justify-center bg-amber-50 shadow-md relative overflow-hidden transform rotate-3">
                          {/* Líneas decorativas dentro del sello */}
                          <div className="absolute inset-0 border-4 border-amber-100 rounded-full m-3"></div>
                          
                          {/* Texto de la fecha en formato vertical y circular */}
                          <div className="text-center">
                            <p className="text-amber-950 font-bold text-sm">15</p>
                            <p className="text-amber-800 text-xs font-serif">de</p>
                            <p className="text-amber-950 font-bold text-sm">ABRIL</p>
                            <p className="text-amber-800 text-xs font-serif">de</p>
                            <p className="text-amber-950 font-bold text-sm">1897</p>
                          </div>
                          
                          {/* Línea de tinta simulada */}
                          <div className="absolute bottom-2 left-1/2 transform -translate-x-1/2 w-20 h-[1px] bg-amber-700 opacity-70"></div>
                        </div>
                        
                        {/* Manchas de tinta alrededor del sello */}
                        <div className="absolute -top-1 -right-1 w-3 h-3 bg-amber-900 rounded-full opacity-20"></div>
                        <div className="absolute top-3 -left-2 w-2 h-4 bg-amber-900 rounded-full opacity-10 transform rotate-45"></div>
                        <div className="absolute -bottom-2 right-5 w-5 h-2 bg-amber-900 rounded-full opacity-15 transform -rotate-12"></div>
                      </div>
                    </div>

                    <div className="font-serif text-amber-950">
                      {/* FECHA EN LA PARTE SUPERIOR - ESTILO MANUSCRITO AUTÉNTICO DE 1897 */}
                      <div className="mb-8 flex justify-end">
                        <div className="relative">
                          {/* Marco con estilo manuscrito de la época */}
                          <div className="relative bg-amber-50 py-2 px-4 transform -rotate-1">
                            {/* Línea superior decorativa */}
                            <div className="absolute top-0 left-0 w-full h-[1px] bg-amber-700 opacity-40"></div>
                            
                            {/* Fecha con estilo caligráfico auténtico de la época */}
                            <div className="px-4 py-1">
                              <p className="text-amber-950 font-serif text-lg tracking-wide">
                                <span className="font-bold">Palencia</span>, a 
                                <span className="font-bold mx-1">15</span> de
                                <span className="font-bold italic mx-1">Abril</span> de
                                <span className="font-bold underline mx-1">1897</span>
                              </p>
                            </div>
                            
                            {/* Ornamento inferior */}
                            <div className="w-3/4 mx-auto h-[1px] mt-2 bg-amber-800 opacity-30"></div>
                            
                            {/* Efecto de pluma y tinta */}
                            <div className="absolute -bottom-4 right-2 w-10 h-6 opacity-20 transform rotate-45">
                              <svg viewBox="0 0 40 20" className="w-full h-full">
                                <path d="M2,10 C10,0 20,5 30,15 S35,15 38,12" stroke="currentColor" strokeWidth="1" fill="none" />
                              </svg>
                            </div>
                          </div>
                          
                          {/* Efecto de salpicadura de tinta */}
                          <div className="absolute -bottom-2 right-6 w-3 h-2 bg-amber-900 rounded-full opacity-10"></div>
                          <div className="absolute top-0 right-3 w-2 h-1 bg-amber-900 rounded-full opacity-10"></div>
                          <div className="absolute top-3 left-2 w-1 h-2 bg-amber-900 rounded-full opacity-10"></div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            
            {/* Componente de Geolocalización */}
            {level.location && (
              <div className="mt-8">
                <GeoLocationChecker 
                  targetLocation={level.location}
                  onLocationReached={handleLocationReached}
                  onError={handleLocationError}
                  distanceThreshold={100} // 100 metros de umbral (se puede ajustar)
                />
              </div>
            )}

            {/* Mostrar pista */}
            {showHint && (
              <div className="mt-4 bg-white rounded-lg shadow-md p-6 border border-amber-200">
                <div className="bg-blue-50 border-l-4 border-blue-400 p-4">
                  <div className="flex">
                    <div className="ml-3">
                      <h3 className="text-sm font-medium text-blue-800">Pista</h3>
                      <p className="mt-1 text-sm text-blue-700">{level.hint}</p>
                    </div>
                  </div>
                </div>
              </div>
            )}

            {/* Botón para mostrar pista */}
            {!showHint && (
              <button
                type="button"
                onClick={handleShowHint}
                className="mt-4 w-full bg-amber-100 text-amber-800 py-2 px-4 rounded-md hover:bg-amber-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-amber-500"
              >
                Mostrar pista
              </button>
            )}
            
            {/* Mensajes */}
            {message.text && (
              <div
                className={`p-4 rounded-md ${
                  message.type === "success" ? "bg-green-50 text-green-800 dark:bg-green-900/30 dark:text-green-200" : "bg-red-50 text-red-800 dark:bg-red-900/30 dark:text-red-200"
                }`}
              >
                {message.text}
              </div>
            )}

            {gameProgress && (
              <div className="mt-8 pt-6 border-t border-gray-200 dark:border-gray-700">
                <h3 className="text-lg font-medium text-gray-900 mb-3 dark:text-white">Estadísticas</h3>
                <div className="grid grid-cols-2 gap-4 sm:grid-cols-3">
                  <div className="bg-gray-50 p-3 rounded-lg text-center dark:bg-boxdark-2">
                    <span className="block text-sm text-gray-500 dark:text-gray-400">Nivel actual</span>
                    <span className="block mt-1 text-xl font-medium text-gray-900 dark:text-white">{gameProgress.currentLevel}</span>
                  </div>
                  <div className="bg-gray-50 p-3 rounded-lg text-center dark:bg-boxdark-2">
                    <span className="block text-sm text-gray-500 dark:text-gray-400">Pistas usadas</span>
                    <span className="block mt-1 text-xl font-medium text-gray-900 dark:text-white">{gameProgress.hintsUsed}</span>
                  </div>
                  <div className="bg-gray-50 p-3 rounded-lg text-center dark:bg-boxdark-2">
                    <span className="block text-sm text-gray-500 dark:text-gray-400">Intentos fallidos</span>
                    <span className="block mt-1 text-xl font-medium text-gray-900 dark:text-white">{gameProgress.wrongAttempts}</span>
                  </div>
                </div>
              </div>
            )}
          </div>
        </div>
      </LevelGuard>
    );
  }

  // Renderizado para los otros niveles (con soporte para geolocalización)
  return (
    <LevelGuard>
      <div className="min-h-screen bg-gray-100 py-12 px-4 sm:px-6 lg:px-8 dark:bg-boxdark-2">
        <div className="max-w-3xl mx-auto bg-white rounded-xl shadow-md overflow-hidden dark:bg-boxdark">
          <div className="p-8">
            <div className="mb-6 flex justify-between items-center">
              <span className="inline-flex items-center px-3 py-1 bg-yellow-100 text-yellow-800 rounded-full text-sm font-medium dark:bg-yellow-900/30 dark:text-yellow-200">
                Nivel {currentLevel}
              </span>
            </div>

            <h1 className="text-2xl font-bold text-gray-900 mb-4 dark:text-white">{level.title}</h1>
            
            {level.imageUrl && (
              <div className="mb-6 overflow-hidden rounded-lg">
                <img
                  src={level.imageUrl}
                  alt={`Imagen del nivel ${currentLevel}`}
                  className="w-full h-64 object-cover"
                />
              </div>
            )}

            <div className="prose max-w-none mb-6 dark:prose-invert">
              <p>{level.description}</p>
            </div>

            {/* Componente de Geolocalización (si el nivel tiene ubicación) */}
            {level.location ? (
              <div className="mb-6">
                <GeoLocationChecker 
                  targetLocation={level.location}
                  onLocationReached={handleLocationReached}
                  onError={handleLocationError}
                  distanceThreshold={100} // 100 metros de umbral
                />
              </div>
            ) : (
              // Formulario de respuesta normal si no hay geolocalización
              <form onSubmit={handleSubmitAnswer} className="mb-6 space-y-4">
                <div>
                  <label htmlFor="answer" className="block text-sm font-medium text-gray-700 dark:text-gray-300">
                    Tu respuesta
                  </label>
                  <input
                    type="text"
                    id="answer"
                    value={answer}
                    onChange={(e) => setAnswer(e.target.value)}
                    className="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-yellow-500 focus:border-yellow-500 dark:bg-boxdark-2 dark:border-gray-600 dark:text-white"
                    placeholder="Escribe tu respuesta..."
                    required
                  />
                </div>

                <div className="flex space-x-4">
                  <button
                    type="submit"
                    className="flex-1 bg-yellow-600 text-white py-2 px-4 rounded-md hover:bg-yellow-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-yellow-500 dark:focus:ring-offset-boxdark"
                  >
                    Comprobar
                  </button>
                  
                  {!showHint && (
                    <button
                      type="button"
                      onClick={handleShowHint}
                      className="bg-gray-200 text-gray-800 py-2 px-4 rounded-md hover:bg-gray-300 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500 dark:bg-gray-700 dark:text-white dark:hover:bg-gray-600 dark:focus:ring-offset-boxdark"
                    >
                      Mostrar pista
                    </button>
                  )}
                </div>
              </form>
            )}

            {showHint && (
              <div className="mb-6 bg-blue-50 border-l-4 border-blue-400 p-4 dark:bg-blue-900/30 dark:border-blue-700">
                <div className="flex">
                  <div className="ml-3">
                    <h3 className="text-sm font-medium text-blue-800 dark:text-blue-300">Pista</h3>
                    <p className="mt-1 text-sm text-blue-700 dark:text-blue-200">{level.hint}</p>
                  </div>
                </div>
              </div>
            )}

            {message.text && (
              <div
                className={`p-4 rounded-md ${
                  message.type === "success" ? "bg-green-50 text-green-800 dark:bg-green-900/30 dark:text-green-200" : "bg-red-50 text-red-800 dark:bg-red-900/30 dark:text-red-200"
                }`}
              >
                {message.text}
              </div>
            )}

            {gameProgress && (
              <div className="mt-8 pt-6 border-t border-gray-200 dark:border-gray-700">
                <h3 className="text-lg font-medium text-gray-900 mb-3 dark:text-white">Estadísticas</h3>
                <div className="grid grid-cols-2 gap-4 sm:grid-cols-3">
                  <div className="bg-gray-50 p-3 rounded-lg text-center dark:bg-boxdark-2">
                    <span className="block text-sm text-gray-500 dark:text-gray-400">Nivel actual</span>
                    <span className="block mt-1 text-xl font-medium text-gray-900 dark:text-white">{gameProgress.currentLevel}</span>
                  </div>
                  <div className="bg-gray-50 p-3 rounded-lg text-center dark:bg-boxdark-2">
                    <span className="block text-sm text-gray-500 dark:text-gray-400">Pistas usadas</span>
                    <span className="block mt-1 text-xl font-medium text-gray-900 dark:text-white">{gameProgress.hintsUsed}</span>
                  </div>
                  <div className="bg-gray-50 p-3 rounded-lg text-center dark:bg-boxdark-2">
                    <span className="block text-sm text-gray-500 dark:text-gray-400">Intentos fallidos</span>
                    <span className="block mt-1 text-xl font-medium text-gray-900 dark:text-white">{gameProgress.wrongAttempts}</span>
                  </div>
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    </LevelGuard>
  );
};

export default GameLevelPage;